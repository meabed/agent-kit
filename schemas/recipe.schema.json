{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/meabed/agent-kit/schemas/recipe.schema.json",
  "title": "Agent Kit Recipe",
  "type": "object",
  "required": ["id", "title", "summary", "type", "topics"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 4
    },
    "summary": {
      "type": "string",
      "minLength": 12
    },
    "type": {
      "type": "string",
      "enum": [
        "agent",
        "command",
        "config",
        "loop",
        "prompt",
        "resource",
        "skill",
        "tool",
        "workflow"
      ]
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "date": {
      "type": "string"
    },
    "sourceArtifact": {
      "type": "string"
    },
    "siteUrl": {
      "type": "string"
    },
    "sourcePath": {
      "type": "string"
    }
  }
}
