{
  "name": "@meabed/skills",
  "version": "0.1.0",
  "description": "Hand-authored prompts, skills, commands, agents, and plugins for coding agents.",
  "homepage": "https://github.com/meabed/agent-kit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/meabed/agent-kit.git"
  },
  "bin": {
    "skills": "./dist/cli.js"
  },
  "files": [
    ".claude-plugin",
    "agents",
    "commands",
    "dist",
    "docs",
    "prompts",
    "skills",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "bun build ./src/cli.ts --target node --format esm --outfile dist/cli.js && chmod +x dist/cli.js",
    "dev": "bun src/cli.ts",
    "validate": "bun src/cli.ts validate",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "prepack": "bun run build && bun run validate"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260628.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0"
  },
  "packageManager": "bun@1.3.14"
}
