{
  "name": "@meabed/agent-kit",
  "version": "0.1.0",
  "description": "Prompts, skills, commands, and repo rules for coding agents.",
  "homepage": "https://mo.ca/ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/meabed/agent-kit.git"
  },
  "bin": {
    "meabed-agent": "./dist/cli.js"
  },
  "files": [
    "catalog",
    "dist",
    "docs",
    "generated",
    "registry.json",
    "schemas",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "bun build ./src/cli.ts --target node --format esm --outfile dist/cli.js && chmod +x dist/cli.js",
    "dev": "bun src/cli.ts",
    "sync:site": "bun src/cli.ts sync-site --site ../site --write",
    "generate": "bun src/cli.ts generate && oxfmt generated registry.json",
    "validate": "bun src/cli.ts validate",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "prepack": "bun run build && bun run validate"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260628.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0"
  },
  "packageManager": "bun@1.3.14"
}
